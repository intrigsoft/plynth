{
  "name": "@plynth/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Plynth backend — projects + documents API (NestJS)",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "typecheck:mcp": "tsc -p mcp/tsconfig.json",
    "mcp": "tsx mcp/main.ts",
    "mcp:http": "tsx mcp/http.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/serve-static": "^4.0.2",
    "@plynth/shared": "*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
  }
}
