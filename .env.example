# Backend + MCP server — DioscHub integration. Copy to .env (or set in the env).
#
# The artifact secret signs the device-bound BYOA token. It MUST be identical
# between the bind minter (backend) and the MCP verifier (Plynth REST), so set
# the same value in whatever process(es) run them.

# --- backend bind endpoint (/api/diosc/bind) ---
DIOSC_HUB_URL=http://localhost:3333
DIOSC_EMBED_KEY=                       # same value as VITE_DIOSC_EMBED_KEY
PLYNTH_ARTIFACT_SECRET=change-me-to-a-long-random-string

# --- MCP server (backend/mcp, run via `npm run mcp:http` in backend) ---
# Where the MCP relay reaches Plynth's REST API (the backend, with global prefix /api).
PLYNTH_API_URL=http://localhost:3000
# Port the hub connects to (serverUrl http://<host>:<port>/mcp). Railway injects PORT.
PLYNTH_MCP_PORT=5174
# Optional: artifact used for local stdio testing (`npm run mcp`) when there is
# no per-call _meta identity. Not used by the HTTP transport.
# PLYNTH_ARTIFACT=
